# Chargé automatiquement par `vite build` (mode production). Pas de secrets ici.
# Les clés Firebase peuvent rester dans .env.local au moment du build, ou être injectées en CI.

VITE_USE_FICTITIOUS_DATA=false

# OAuth Nylas réel (boutons Gmail/Outlook + Cloud Functions).
VITE_NYLAS_ENABLED=true
VITE_FIREBASE_FUNCTIONS_REGION=us-central1
