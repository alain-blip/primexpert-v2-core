# primexpert-app-v2 : ajoute ces lignes dans .env.local (ne pas commiter).
# Console Firebase → primexpert-app-v2 → Paramètres → votre appli Web → config SDK.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=primexpert-app-v2.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=primexpert-app-v2
VITE_FIREBASE_STORAGE_BUCKET=primexpert-app-v2.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Même ID que dans firebase.json si tu utilises une base nommée :
VITE_FIRESTORE_DATABASE_ID=ai-studio-1214d671-efd2-47da-93b7-425feb92155a

# Listings : données de démo si pipeline vide. En production : false ou absent (obligatoire).
VITE_USE_FICTITIOUS_DATA=false
