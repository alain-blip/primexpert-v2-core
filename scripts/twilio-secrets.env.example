# Fichier modèle — copier vers twilio-secrets.local.env (jamais versionné Git).
# Remplir depuis la console Twilio : https://console.twilio.com
#
# TWILIO_SID          → Account SID (commence par AC…)
# TWILIO_API_KEY      → API Key SID (commence par SK…)
# TWILIO_API_SECRET   → Secret affiché UNE FOIS à la création de la clé API (pas le SK… ni le AC…)
# TWILIO_TWIML_APP_SID → TwiML App « Primexpert V2 » (commence par AP…)

TWILIO_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
TWILIO_TWIML_APP_SID=
