// =============================================================================
// SILOS 2026 v4 — Firebase Storage Security Rules
//
// Drive + Espace Documents : silo `primexpert/{brokerId}/…` (brokerId == auth.uid)
// Legacy lecture seule : `properties/{propertyId}/documents/…` (firestore.get)
// =============================================================================

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    match /{allPaths=**} {
      allow read, write: if false;
    }

    function residenceRef(propertyId) {
      return /databases/ai-studio-1214d671-efd2-47da-93b7-425feb92155a/documents/residences/$(propertyId);
    }

    function isLegacyResidenceOwner(propertyId) {
      return request.auth != null
        && firestore.exists(residenceRef(propertyId))
        && firestore.get(residenceRef(propertyId)).data.courtiersResponsables == request.auth.uid;
    }

    // Legacy — fichiers déjà téléversés sous l’ancien chemin (lecture / suppression propriétaire)
    match /properties/{propertyId}/documents/{category}/{fileName} {
      allow read, delete: if isLegacyResidenceOwner(propertyId);
      allow create, update: if false;
    }

    // Espace Documents — diligence (primexpert / courtier / propriété / dossier)
    match /primexpert/{brokerId}/properties/{propertyId}/documents/{category}/{fileName} {
      allow read: if request.auth != null && request.auth.uid == brokerId;

      allow create: if request.auth != null
                    && request.auth.uid == brokerId
                    && request.resource.size < 25 * 1024 * 1024
                    && request.resource.metadata.courtiersResponsables == brokerId;

      allow delete: if request.auth != null && request.auth.uid == brokerId;
    }

    // Drive PrimeXpert — reste du silo courtier
    match /primexpert/{brokerId}/{allPaths=**} {
      allow read: if request.auth != null
                  && request.auth.uid == brokerId;

      allow write: if request.auth != null
                   && request.auth.uid == brokerId
                   && request.resource.size < 25 * 1024 * 1024
                   && request.resource.metadata.courtiersResponsables == brokerId;

      allow delete: if false;
    }
  }
}
