{
  "name": "primexpert-functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "sync:core-diffusion": "node scripts/sync-core-diffusion.cjs",
    "prebuild": "npm run sync:core-diffusion",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "deploy": "npm run build && FUNCTIONS_DISCOVERY_TIMEOUT=60 firebase deploy --only functions"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.10.0",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "typescript": "~5.8.2"
  }
}
