rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isOrgMember(orgId) { 
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId; 
    }

    // Users (Split PII logic)
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isOrgMember(existing().orgId));
      allow create: if isOwner(userId) && 
        incoming().keys().hasAll(['uid', 'email', 'displayName', 'orgId', 'role']) &&
        incoming().uid == userId &&
        incoming().email == request.auth.token.email &&
        incoming().role in ['admin', 'admin_system']; // Premier compte : admin ; direction : admin_system (console)
      allow update: if isOwner(userId) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoUrl', 'licenseName', 'title', 'agency', 'photoUpdatedAt', 'role', 'trialStartDate', 'accessibleSilos']);

      // Analyses IA Mailbox (E-2 persistance) — une doc par messageId, propriétaire = courtier.
      match /mailbox_analyses/{messageId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) &&
          incoming().messageId == messageId &&
          incoming().mergedParse is map &&
          incoming().analyzedAtMillis is int &&
          incoming().matchedResidenceId is string &&
          (!incoming().keys().hasAny(['replyDraftAtMillis']) ||
            incoming().replyDraftAtMillis is int ||
            incoming().replyDraftAtMillis == null);
      }

      // E-3 — Comptes-rendus d’appels (une doc par driveDocumentId, liée à residenceId).
      match /call_analyses/{analysisId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) &&
          incoming().driveDocumentId == analysisId &&
          incoming().residenceId is string &&
          incoming().updatedAtMillis is int &&
          incoming().pipelineStatus in ['recorded', 'transcribing', 'analyzing', 'analyzed', 'failed'];
      }
    }

    // Organizations
    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId);
      allow create: if isSignedIn(); // Allow during first signup
      allow update: if isOrgMember(orgId) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'admin_system'];
    }

    // Shared Collection Pattern for multi-tenancy
    match /organizations/{orgId}/listings/{listingId} {
      allow read: if isOrgMember(orgId);
      allow write: if isOrgMember(orgId);
    }

    match /organizations/{orgId}/contacts/{contactId} {
      allow read: if isOrgMember(orgId);
      allow write: if isOrgMember(orgId);
    }

    match /organizations/{orgId}/transactions/{transactionId} {
      allow read: if isOrgMember(orgId);
      allow write: if isOrgMember(orgId);
    }

    // ========================================================================
    // SILOS 2026 v4 — Multi-tenant flat collections (brokerId-based)
    //
    // Modèle : champ canonique `courtiersResponsables` == request.auth.uid
    // Source : @primexpert/core/tenant (TENANT_FIELD = 'courtiersResponsables')
    // Phase  : C.1 — Sécurité serveur (sans déploiement, en attente validation Alain)
    //
    // NOTE GOUVERNANCE — Cohabitation de DEUX modèles multi-tenant :
    //   1) Org-based : organizations/{orgId}/listings, contacts, transactions
    //   2) Broker-based : /residences, /drive_documents (filtre courtiersResponsables)
    // À trancher en Phase D : migrer org → broker OU garder les deux.
    // ========================================================================

    function isTenantOwner() {
      return isSignedIn() && existing().courtiersResponsables == request.auth.uid;
    }

    function isIncomingTenantOwner() {
      return isSignedIn() && incoming().courtiersResponsables == request.auth.uid;
    }

    // residences — collection multi-tenant racine (Brief Silos 2026 v4 §5)
    match /residences/{residenceId} {
      allow read:   if isTenantOwner();
      allow create: if isIncomingTenantOwner();
      allow update: if isTenantOwner() && isIncomingTenantOwner();
      allow delete: if isTenantOwner();
    }

    // proprietes — dossiers / fiches Copilote migrés (Phase 2) ; même clé tenant que `residences`.
    match /proprietes/{proprieteId} {
      allow read:   if isTenantOwner();
      allow create: if isIncomingTenantOwner();
      allow update: if isTenantOwner() && isIncomingTenantOwner();
      allow delete: if isTenantOwner();
    }

    match /drive_documents/{docId} {
      allow read:   if isTenantOwner();
      allow create: if isIncomingTenantOwner();
      allow update: if isTenantOwner() && isIncomingTenantOwner();
      // Suppression interdite (OACIQ — conservation 6 ans, audit log immuable)
      allow delete: if false;
    }
  }
}
