rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Collection group `messages` — analyses messagerie (Dashboard, Listings, chronologie).
    // SSOT chemin : users/{uid}/email_threads/{threadId}/messages/{messageId}
    match /{path=**}/messages/{messageId} {
      allow read: if isSignedIn() && (
        resource.data.brokerId == request.auth.uid ||
        resource.data.authorId == request.auth.uid ||
        (resource.data.threadId is string &&
          exists(/databases/$(database)/documents/users/$(request.auth.uid)/email_threads/$(resource.data.threadId)))
      );
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isOrgMember(orgId) { 
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId == orgId; 
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isOrgAdmin(orgId) {
      return isOrgMember(orgId) && userProfile().role in ['admin', 'admin_system'];
    }

    // Users (Split PII logic)
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isOrgMember(existing().orgId));
      allow create: if isOwner(userId) && 
        incoming().keys().hasAll(['uid', 'email', 'displayName', 'orgId', 'role']) &&
        incoming().uid == userId &&
        incoming().email == request.auth.token.email &&
        incoming().role in ['admin', 'admin_system']; // Premier compte : admin ; direction : admin_system (console)
      allow update: if isOwner(userId) &&
        incoming().diff(existing()).affectedKeys().hasOnly([
          'displayName', 'photoUrl', 'licenseName', 'title', 'agency', 'photoUpdatedAt',
          'role', 'trialStartDate', 'accessibleSilos', 'firstName', 'lastName', 'phone',
          'j7Survey', 'lastEmailSent', 'emailAccounts'
        ]);

      // Analyses IA Mailbox (E-2 persistance) — une doc par messageId, propriétaire = courtier.
      match /mailbox_analyses/{messageId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) &&
          incoming().messageId == messageId &&
          incoming().mergedParse is map &&
          incoming().analyzedAtMillis is int &&
          incoming().matchedResidenceId is string &&
          (!incoming().keys().hasAny(['replyDraftAtMillis']) ||
            incoming().replyDraftAtMillis is int ||
            incoming().replyDraftAtMillis == null);
      }

      // E-3 — Comptes-rendus d’appels (une doc par driveDocumentId, liée à residenceId).
      match /call_analyses/{analysisId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) &&
          incoming().driveDocumentId == analysisId &&
          incoming().residenceId is string &&
          incoming().updatedAtMillis is int &&
          incoming().pipelineStatus in ['recorded', 'transcribing', 'analyzing', 'analyzed', 'failed'];
      }

      // Messagerie synchronisée — fils + messages temps réel (multi-inbox).
      match /email_threads/{threadId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) &&
          incoming().brokerId == userId;
        allow update, delete: if isOwner(userId);

        match /messages/{messageId} {
          allow read: if isOwner(userId);
          allow update: if isOwner(userId);
          allow delete: if isOwner(userId);
          allow create: if isOwner(userId) &&
            incoming().direction in ['inbound', 'outbound'] &&
            incoming().sentAtMillis is int &&
            (!('body' in incoming()) || incoming().body is string);
        }
      }
    }

    // File d'attente courriels nurture (J7 alerte support, J21 courtier, etc.)
    match /email_outbox/{outboxId} {
      allow create: if isSignedIn() &&
        incoming().userId == request.auth.uid &&
        incoming().status == 'pending';
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Organizations
    match /organizations/{orgId} {
      allow read: if isOrgMember(orgId);
      allow create: if isSignedIn(); // Allow during first signup
      allow update: if isOrgMember(orgId) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'admin_system'];
    }

    // Shared Collection Pattern for multi-tenancy
    match /organizations/{orgId}/listings/{listingId} {
      allow read: if isOrgMember(orgId);
      allow write: if isOrgMember(orgId);
    }

    // CRM contacts — ownerId + pool RPA (AGENCY_SHARED) ; réassignation leads pub AGENCY_AD
    match /organizations/{orgId}/contacts/{contactId} {
      allow read: if isOrgMember(orgId) && (
        resource.data.ownerId == request.auth.uid ||
        resource.data.visibility == 'AGENCY_SHARED'
      );

      allow create: if isOrgMember(orgId) &&
        incoming().ownerId == request.auth.uid &&
        incoming().orgId == orgId &&
        incoming().silo in ['RESIDENTIEL', 'RES_COM', 'COMMERCIAL_SPEC'] &&
        incoming().visibility in ['PRIVATE', 'AGENCY_SHARED'] &&
        incoming().leadSource in ['AGENCY_AD', 'BROKER_GENERATED', 'REFERRAL', 'IMPORT_LEGACY', 'OTHER'] &&
        incoming().nom is string && incoming().nom.size() > 0 &&
        incoming().dateNaissance is string && incoming().dateNaissance.size() > 0 &&
        incoming().occupationProfession is string && incoming().occupationProfession.size() > 0 &&
        incoming().adresse is map;

      allow update: if isOrgMember(orgId) && (
        (resource.data.ownerId == request.auth.uid &&
         incoming().ownerId == resource.data.ownerId) ||
        (isOrgAdmin(orgId) &&
         resource.data.leadSource == 'AGENCY_AD' &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ownerId', 'updatedAt']))
      );

      allow delete: if isOrgMember(orgId) && resource.data.ownerId == request.auth.uid;
    }

    match /organizations/{orgId}/transactions/{transactionId} {
      allow read: if isOrgMember(orgId);
      allow write: if isOrgMember(orgId);
    }

    // Mes Documents — espace de travail agence (gabarits ; distinct des inscriptions)
    match /organizations/{orgId}/agencyDocuments/{docId} {
      allow read: if isOrgMember(orgId);
      allow create: if isOrgMember(orgId) &&
        incoming().orgId == orgId &&
        incoming().uploadedBy == request.auth.uid &&
        incoming().category in ['gabarits', 'notes', 'autre'] &&
        incoming().fileName is string &&
        incoming().storagePath is string;
      allow update, delete: if isOrgMember(orgId) &&
        resource.data.uploadedBy == request.auth.uid;
    }

    // ========================================================================
    // SILOS 2026 v4 — Multi-tenant flat collections (brokerId-based)
    //
    // Modèle : champ canonique `courtiersResponsables` == request.auth.uid
    // Source : @primexpert/core/tenant (TENANT_FIELD = 'courtiersResponsables')
    // Phase  : C.1 — Sécurité serveur (sans déploiement, en attente validation Alain)
    //
    // NOTE GOUVERNANCE — Cohabitation de DEUX modèles multi-tenant :
    //   1) Org-based : organizations/{orgId}/listings, contacts, transactions
    //   2) Broker-based : /residences, /drive_documents (filtre courtiersResponsables)
    // À trancher en Phase D : migrer org → broker OU garder les deux.
    // ========================================================================

    function isTenantOwner() {
      return isSignedIn() && existing().courtiersResponsables == request.auth.uid;
    }

    function isIncomingTenantOwner() {
      return isSignedIn() && incoming().courtiersResponsables == request.auth.uid;
    }

    /** Catalogue partagé : fiche sans courtier assigné (champ vide ou absent). */
    function isSharedCatalogResidence() {
      return isSignedIn() && (
        !('courtiersResponsables' in existing()) ||
        existing().courtiersResponsables == null ||
        existing().courtiersResponsables == ''
      );
    }

  function residenceDoc(residenceId) {
    return get(/databases/$(database)/documents/residences/$(residenceId)).data;
  }

  /** Lecture sous-collections (financial/dataV2, documents/) — aligné racine residences. */
  function canReadResidenceSubcollection(residenceId) {
    let data = residenceDoc(residenceId);
    return isSignedIn() && (
      data.courtiersResponsables == request.auth.uid ||
      !('courtiersResponsables' in data) ||
      data.courtiersResponsables == null ||
      data.courtiersResponsables == ''
    );
  }

  function isResidenceTenantOwner(residenceId) {
    return isSignedIn() &&
      residenceDoc(residenceId).courtiersResponsables == request.auth.uid;
  }

    // residences — collection multi-tenant racine (Brief Silos 2026 v4 §5)
    match /residences/{residenceId} {
      allow read:   if isTenantOwner() || isSharedCatalogResidence();
      allow create: if isIncomingTenantOwner();
      allow update: if (isTenantOwner() && isIncomingTenantOwner())
        || (
          isSharedCatalogResidence() &&
          incoming().courtiersResponsables == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['courtiersResponsables'])
        );
      allow delete: if isTenantOwner();

      // Hub Finance V2 — financial/dataV2 (normalizeFinancialData, Bilan, Revenus & Dépenses)
      match /financial/{financialDocId} {
        allow read: if canReadResidenceSubcollection(residenceId);
        allow create, update: if isResidenceTenantOwner(residenceId);
        allow delete: if isResidenceTenantOwner(residenceId);
      }

      // Bibliothèque documentaire migrée depuis Copilote
      match /documents/{documentId} {
        allow read: if canReadResidenceSubcollection(residenceId);
        allow create, update: if isResidenceTenantOwner(residenceId);
        allow delete: if isResidenceTenantOwner(residenceId);
      }
    }

    // proprietes — dossiers / fiches Copilote migrés (Phase 2) ; même clé tenant que `residences`.
    match /proprietes/{proprieteId} {
      allow read:   if isTenantOwner();
      allow create: if isIncomingTenantOwner();
      allow update: if isTenantOwner() && isIncomingTenantOwner();
      allow delete: if isTenantOwner();
    }

    match /drive_documents/{docId} {
      allow read:   if isTenantOwner();
      allow create: if isIncomingTenantOwner();
      allow update: if isTenantOwner() && isIncomingTenantOwner();
      // Suppression interdite (OACIQ — conservation 6 ans, audit log immuable)
      allow delete: if false;
    }

    // Big Data marché — entrées strictement anonymisées (pas d'adresse ni de fiche résidence).
    match /market_analytics_raw/{entryId} {
      allow create: if isSignedIn() &&
        incoming().siloType is string &&
        incoming().regionAdministrative is string &&
        incoming().anneeDonnees is int &&
        incoming().provenance in ['etats_financiers', 'rapport_evaluation'] &&
        incoming().validatedAmounts is list &&
        (
          incoming().validatedAmounts.size() > 0 ||
          ('comparableSnapshot' in incoming() && incoming().comparableSnapshot is map)
        ) &&
        !incoming().keys().hasAny([
          'address', 'residenceId', 'propertyId', 'residenceName', 'fileName', 'storagePath'
        ]);
      allow read: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
